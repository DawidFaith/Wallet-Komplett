# Bright Data Web Unlocker (Instagram-Profil-Verifizierung)
# API-Key unter: https://brightdata.com → API & Integrations → API Token
BRIGHTDATA_API_KEY=your_brightdata_api_key
# Zone-Name aus dem Bright Data Dashboard (Standard: web_unlocker1)
BRIGHTDATA_ZONE=web_unlocker1

# Thirdweb Configuration
NEXT_PUBLIC_TEMPLATE_CLIENT_ID=your_thirdweb_client_id

# Basescan API Key für Base-Chain-Transaktionen
# Beantrage einen kostenlosen API-Key auf https://basescan.org/apis
NEXT_PUBLIC_BASESCAN_API_KEY=your_basescan_api_key

# Stripe Configuration (für D.INVEST Token-Käufe)
# 🚀 NUR LIVE MODUS - Test-Modus ist deaktiviert
# Live-Keys werden automatisch von Vercel Environment Variables geladen
# 
# ⚠️  WICHTIG: Nur LIVE Keys werden akzeptiert!
# Die folgenden LIVE Environment Variables müssen in Vercel konfiguriert sein:
# - NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51xxxxxxx
# - STRIPE_SECRET_KEY=sk_live_51xxxxxxx
# - STRIPE_WEBHOOK_SECRET=whsec_xxxxxxx (für Live-Webhook)
#
# 🚨 Test-Keys (pk_test_, sk_test_) werden automatisch ABGELEHNT
#
# Live Webhook URL: https://wallet-komplett.vercel.app/api/stripe-webhook
# Erforderliche Webhook Events: 
# - payment_intent.succeeded
# - payment_intent.payment_failed  
# - payment_intent.canceled